@model StarredPupilConfirmationViewModel
@{
    ViewData["Title"] = "Confirm pupil(s) will join establishment";
}

<form method="POST" asp-controller="@Model.ConfirmationReturnController" asp-action="@Model.ConfirmationReturnAction">
    <input type="hidden" name="SelectedPupil" value="@Model.SelectedPupil" />
    <input type="hidden" name="DownloadType" value="@Model.DownloadType">
    <input type="hidden" name="LearnerNumbers" value="@Model.LearnerNumbers">

    <div class="govuk-form-group">
        <fieldset class="govuk-fieldset" aria-describedby="waste-hint">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
                <h1 class="govuk-fieldset__heading">
                    Confirm pupil(s) will join establishment
                </h1>
            </legend>
            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                @if (Model.ConfirmationError)
                {
                    <p class="govuk-error-message">
                        <span class="govuk-visually-hidden">Error:</span> You must confirm you have read and understood the conditions before continuing
                    </p>
                }
                <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" asp-for="ConfirmationGiven" name="ConfirmationGiven" type="checkbox">
                    <label class="govuk-label govuk-checkboxes__label" for="waste">
                        The selected pupil(s) are outside of the statutory age for your establishment. To continue, you need to confirm that they have, or will join this establishment.
                    </label>
                </div>
            </div>
        </fieldset>

        <div class="govuk-button-group">
            <button type="submit" class="govuk-button" data-module="govuk-button" value="confirmButton">
                Continue
            </button>
            <button class="govuk-button app-button-as-link" asp-controller="@Model.CancelReturnController" asp-action="@Model.CancelReturnAction" type="submit" name="cancelButton" value="cancelButton" aria-label="Cancel">
                Cancel
            </button>
        </div>
    </div>
</form>
