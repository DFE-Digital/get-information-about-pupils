@model LearnerNumberSearchViewModel
@{
    ViewData["Title"] = Model.PageHeading;
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-xl" id="search-type--text">@Model.PageHeading</h1>

        <partial name="~/Views/Shared/LearnerNumber/_SearchBox.cshtml" model="Model" />
        <partial name="~/Views/Shared/LearnerNumber/_Results.cshtml" model="Model" />

        <div class="govuk-button-group">
            <partial name="~/Views/Shared/_ReleaseTimetablePartial.cshtml" />
            <partial name="~/Views/Shared/_metadataFilesPartial.cshtml" />
        </div>
    </div>
</div>
